-- Hahahano Hub | By Hviet2510
-- UI sử dụng thư viện OrionLib

local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Orion/main/source"))()
local Window = OrionLib:MakeWindow({Name = "Hahahano Hub | By Hviet2510", HidePremium = false, SaveConfig = false, IntroEnabled = false})

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Humanoid = LocalPlayer.Character:WaitForChild("Humanoid")
local HRP = LocalPlayer.Character:WaitForChild("HumanoidRootPart")

-- Fly Toggle
local flying = false
local flyBV = nil

-- Speed Toggle
local speedEnabled = false
local normalWalkSpeed = Humanoid.WalkSpeed
local boostedSpeed = 50

-- UI Tabs
local MainTab = Window:MakeTab({Name = "Main", Icon = "rbxassetid://4483345998", PremiumOnly = false})

MainTab:AddToggle({
	Name = "Fly (Toggle)",
	Default = false,
	Callback = function(Value)
		flying = Value
		if flying then
			flyBV = Instance.new("BodyVelocity", HRP)
			flyBV.Velocity = Vector3.new(0, 50, 0)
			flyBV.MaxForce = Vector3.new(10000, 10000, 10000)
		else
			if flyBV then
				flyBV:Destroy()
				flyBV = nil
			end
		end
	end
})

MainTab:AddToggle({
	Name = "Speed x5 (Toggle)",
	Default = false,
	Callback = function(Value)
		speedEnabled = Value
		if speedEnabled then
			Humanoid.WalkSpeed = boostedSpeed
		else
			Humanoid.WalkSpeed = normalWalkSpeed
		end
	end
})

MainTab:AddButton({
	Name = "Reset Speed",
	Callback = function()
		Humanoid.WalkSpeed = normalWalkSpeed
		speedEnabled = false
	end
})

MainTab:AddButton({
	Name = "Size Up",
	Callback = function()
		LocalPlayer.Character.Humanoid.BodyScale = Vector3.new(2, 2, 2)
	end
})

MainTab:AddButton({
	Name = "Size Down",
	Callback = function()
		LocalPlayer.Character.Humanoid.BodyScale = Vector3.new(0.5, 0.5, 0.5)
	end
})

MainTab:AddTextbox({
	Name = "Get Tool by Name",
	Default = "",
	TextDisappear = true,
	Callback = function(itemName)
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Tool") and obj.Name:lower():find(itemName:lower()) then
				obj.Parent = LocalPlayer.Backpack
			end
		end
	end
})

OrionLib:Init()
