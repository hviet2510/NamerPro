local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

local Window = Rayfield:CreateWindow({
   Name = "Hahahano Hub | By Hviet2510",
   LoadingTitle = "Hahahano Hub",
   LoadingSubtitle = "by Hviet2510",
   ConfigurationSaving = {
      Enabled = false
   },
   Discord = {
      Enabled = false
   },
   KeySystem = false
})

local MainTab = Window:CreateTab("Main Features", 4483362458)

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Humanoid = LocalPlayer.Character:WaitForChild("Humanoid")
local HRP = LocalPlayer.Character:WaitForChild("HumanoidRootPart")

-- Fly Toggle
local flying = false
local flyBV = nil

MainTab:CreateToggle({
	Name = "Fly (Toggle)",
	CurrentValue = false,
	Callback = function(Value)
		flying = Value
		if flying then
			flyBV = Instance.new("BodyVelocity", HRP)
			flyBV.Velocity = Vector3.new(0, 50, 0)
			flyBV.MaxForce = Vector3.new(10000, 10000, 10000)
		else
			if flyBV then
				flyBV:Destroy()
				flyBV = nil
			end
		end
	end
})

-- Speed Toggle
local speedEnabled = false
local normalWalkSpeed = Humanoid.WalkSpeed
local boostedSpeed = 50

MainTab:CreateToggle({
	Name = "Speed x5 (Toggle)",
	CurrentValue = false,
	Callback = function(Value)
		speedEnabled = Value
		if speedEnabled then
			Humanoid.WalkSpeed = boostedSpeed
		else
			Humanoid.WalkSpeed = normalWalkSpeed
		end
	end
})

MainTab:CreateButton({
	Name = "Reset Speed",
	Callback = function()
		Humanoid.WalkSpeed = normalWalkSpeed
		speedEnabled = false
	end
})

MainTab:CreateButton({
	Name = "Size Up",
	Callback = function()
		LocalPlayer.Character.Humanoid.BodyScale = Vector3.new(2,2,2)
	end
})

MainTab:CreateButton({
	Name = "Size Down",
	Callback = function()
		LocalPlayer.Character.Humanoid.BodyScale = Vector3.new(0.5,0.5,0.5)
	end
})

MainTab:CreateInput({
	Name = "Get Tool by Name",
	PlaceholderText = "Nhập tên Tool",
	RemoveTextAfterFocusLost = true,
	Callback = function(itemName)
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Tool") and obj.Name:lower():find(itemName:lower()) then
				obj.Parent = LocalPlayer.Backpack
			end
		end
	end
})
