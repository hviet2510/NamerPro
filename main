local RedzUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/REDzHUB/REDz/main/UiLib.lua"))()

local Window = RedzUI:CreateWindow("Hahahano Hub", "By Hviet2510", 10044538000)
local MainTab = Window:CreateTab("Main")
local AdminTab = Window:CreateTab("Admin")
local SettingsTab = Window:CreateTab("Settings")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Humanoid = LocalPlayer.Character:WaitForChild("Humanoid")
local HRP = LocalPlayer.Character:WaitForChild("HumanoidRootPart")

local enabledFeatures = false
local boostedSpeed = 50

-- Toggle Tổng
SettingsTab:CreateToggle("Bật tất cả chức năng", function(Value)
	enabledFeatures = Value
	if not Value then
		Humanoid.WalkSpeed = 16
		if HRP:FindFirstChild("FlyVelocity") then
			HRP.FlyVelocity:Destroy()
		end
	end
end)

-- Fly
MainTab:CreateToggle("Fly (Bay)", function(Value)
	if enabledFeatures and Value then
		local fly = Instance.new("BodyVelocity", HRP)
		fly.Name = "FlyVelocity"
		fly.Velocity = Vector3.new(0, 50, 0)
		fly.MaxForce = Vector3.new(10000, 10000, 10000)
	else
		if HRP:FindFirstChild("FlyVelocity") then
			HRP.FlyVelocity:Destroy()
		end
	end
end)

-- Speed
MainTab:CreateToggle("Speed x5", function(Value)
	if enabledFeatures and Value then
		Humanoid.WalkSpeed = boostedSpeed
	else
		Humanoid.WalkSpeed = 16
	end
end)

-- Size Up
MainTab:CreateButton("Size Up (To)", function()
	if enabledFeatures then
		for _,v in pairs(LocalPlayer.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.Size = v.Size * 2
			end
		end
	end
end)

-- Size Down
MainTab:CreateButton("Size Down (Nhỏ)", function()
	if enabledFeatures then
		for _,v in pairs(LocalPlayer.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.Size = v.Size * 0.5
			end
		end
	end
end)

-- Get Item
MainTab:CreateTextbox("Tên Item", function(Value)
	if enabledFeatures then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Tool") and obj.Name:lower():find(Value:lower()) then
				obj.Parent = LocalPlayer.Backpack
			end
		end
	end
end)

-- Admin: Teleport
AdminTab:CreateTextbox("Teleport Người chơi", function(Value)
	local target = Players:FindFirstChild(Value)
	if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
		target.Character.HumanoidRootPart.CFrame = HRP.CFrame + Vector3.new(3,0,0)
	end
end)

-- Admin: Kick
AdminTab:CreateTextbox("Kick Người chơi", function(Value)
	local target = Players:FindFirstChild(Value)
	if target then
		target:Kick("Bạn đã bị kick bởi Admin")
	end
end)

-- Admin: Kill
AdminTab:CreateTextbox("Kill Người chơi", function(Value)
	local target = Players:FindFirstChild(Value)
	if target and target.Character and target.Character:FindFirstChild("Humanoid") then
		target.Character.Humanoid.Health = 0
	end
end)
